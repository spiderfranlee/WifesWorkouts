rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isAuthenticated() && isEmailVerified() && request.auth.token.email == 'franny.lee@gmail.com';
    }

    function isOwner(emailId) {
      return isAuthenticated() && isEmailVerified() && request.auth.token.email == emailId;
    }

    match /users/{emailId} {
      allow read, write: if isOwner(emailId) || isAdmin();
      
      match /workouts/{workoutId} {
        allow read, write: if isOwner(emailId) || isAdmin();
      }
    }
    
    // Allow the connection test to succeed for anyone
    match /test/connection {
      allow read: if true;
    }
  }
}
